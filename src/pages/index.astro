---
import SavingsSimulator from '../components/SavingsSimulator';
import RetirementSimulator from '../components/RetirementSimulator';
import '../styles/global.css';

const title = 'NestEgg';
const description = 'Simula el estado de tus ahorros en un intervalo de tiempo determinado. Proyecta tu patrimonio, hipoteca e inversiones al detalle.';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-gradient-to-br from-white via-gray-50 to-white min-h-screen">
    <nav class="flex justify-center pt-6 pb-2 px-3 sm:px-4 lg:px-8">
      <div class="mx-auto max-w-6xl w-full flex items-center justify-center">
        <div class="relative" id="nav-dropdown">
          <button
            id="nav-trigger"
            class="group flex items-center gap-2.5 px-4 py-2.5 bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md hover:border-gray-300 transition-all text-sm font-semibold text-gray-900 cursor-pointer"
          >
            <span id="nav-label">Simulador de Ahorros</span>
            <svg id="nav-arrow" class="w-4 h-4 text-gray-400 transition-transform duration-200 group-hover:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id="nav-menu"
            class="absolute left-1/2 -translate-x-1/2 top-full mt-2 w-72 sm:w-80 bg-white border border-gray-200 rounded-xl shadow-lg overflow-hidden opacity-0 invisible transition-all duration-200 z-50"
          >
            <button class="flex items-start gap-3.5 w-full px-5 py-4 text-left hover:bg-gray-50 transition-colors border-b border-gray-100 last:border-b-0" data-tab="savings">
              <svg class="w-5 h-5 text-gray-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-900">Simulador de Ahorros</p>
                <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">Proyecta tu patrimonio, hipoteca e inversiones al detalle.</p>
              </div>
              <svg class="nav-check w-4 h-4 text-gray-900 mt-1 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </button>
            <button class="flex items-start gap-3.5 w-full px-5 py-4 text-left hover:bg-gray-50 transition-colors border-b border-gray-100 last:border-b-0" data-tab="retirement">
              <svg class="w-5 h-5 text-gray-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
              </svg>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-900">Calculadora de Jubilación</p>
                <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">Planifica cuándo jubilarte gestionando bien tus ahorros.</p>
              </div>
              <svg class="nav-check w-4 h-4 text-gray-900 mt-1 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </nav>
    <div id="tab-savings" class="tab-content">
      <SavingsSimulator client:load />
    </div>
    <div id="tab-retirement" class="tab-content hidden">
      <RetirementSimulator client:load />
    </div>
    <script>
      const trigger = document.getElementById('nav-trigger');
      const menu = document.getElementById('nav-menu');
      const navArrow = document.getElementById('nav-arrow');
      const navLabel = document.getElementById('nav-label');
      const dropdownItems = menu.querySelectorAll('button[data-tab]');
      const navChecks = document.querySelectorAll('.nav-check');
      const contents = {
        savings: document.getElementById('tab-savings'),
        retirement: document.getElementById('tab-retirement'),
      };
      let isOpen = false;

      function closeMenu() {
        isOpen = false;
        menu.classList.add('opacity-0', 'invisible');
        navArrow.classList.remove('rotate-180');
      }

      function openMenu() {
        isOpen = true;
        menu.classList.remove('opacity-0', 'invisible');
        navArrow.classList.add('rotate-180');
      }

      function switchTab(tab) {
        const activeItem = menu.querySelector(`button[data-tab="${tab}"]`);
        navLabel.textContent = activeItem.querySelector('p:first-child').textContent;
        navChecks.forEach(c => c.classList.add('hidden'));
        activeItem.querySelector('.nav-check')?.classList.remove('hidden');
        Object.entries(contents).forEach(([key, el]) => {
          el?.classList.toggle('hidden', key !== tab);
        });
      }

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        isOpen ? closeMenu() : openMenu();
      });

      document.addEventListener('click', closeMenu);

      dropdownItems.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const tab = btn.dataset.tab;
          switchTab(tab);
          closeMenu();
        });
      });

      // Initialise
      switchTab('savings');
    </script>
  </body>
</html>
