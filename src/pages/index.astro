---
import SavingsSimulator from '../components/SavingsSimulator';
import '../styles/global.css';

const title = 'Simulador de Ahorros';
const description = 'Simula el estado de tus ahorros en un intervalo de tiempo determinado';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#3b82f6" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-gradient-to-br from-white via-gray-50 to-white min-h-screen">
    <SavingsSimulator client:load />
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }

  html {
    font-family: 'Heebo', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: 'Signika', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }
</style>
