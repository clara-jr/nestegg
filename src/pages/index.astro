---
import SavingsSimulator from '../components/SavingsSimulator';
import RetirementSimulator from '../components/RetirementSimulator';
import AffordabilitySimulator from '../components/AffordabilitySimulator';
import '../styles/global.css';

const title = 'NestEgg';
const description = 'Planifica tus finanzas personales: simula la evolución de tus ahorros e inversiones, calcula cuándo jubilarte y descubre qué casa puedes permitirte.';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://clara-jr.github.io/nestegg/thumbnail.png" />
    <meta property="og:image:width" content="674" />
    <meta property="og:image:height" content="470" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:type" content="website" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:site" content="@clear_is_me" />
    <meta property="twitter:creator" content="@clear_is_me" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://clara-jr.github.io/nestegg/thumbnail.png" />
    <link rel="icon" type="image/svg+xml" href="/nestegg/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-gradient-to-br from-white via-gray-50 to-white min-h-screen">
    <nav class="flex justify-center px-3 sm:px-4 lg:px-8 pt-10 pb-2">
      <div class="mx-auto max-w-6xl w-full flex items-center justify-center">
        <div class="relative w-full max-w-xl sm:max-w-3xl" id="nav-container">
          <!-- Mobile trigger -->
          <button id="nav-mobile-trigger" class="cursor-pointer flex sm:hidden items-center gap-2.5 w-full px-4 py-3 bg-white border border-gray-200 rounded-xl shadow-sm text-sm font-semibold text-gray-900 cursor-pointer">
            <span id="nav-mobile-icon" class="text-lg flex-shrink-0">💰</span>
            <span id="nav-mobile-label">Simulador de Ahorros</span>
            <svg id="nav-mobile-arrow" class="w-4 h-4 text-gray-400 ml-auto transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="nav-mobile-menu" class="hidden sm:hidden absolute left-0 right-0 top-full mt-2 bg-white border border-gray-200 rounded-xl shadow-lg overflow-hidden z-50">
            <button class="cursor-pointer tab-btn flex items-center gap-3 w-full px-5 py-4 text-left" data-tab="savings">
              <span class="text-lg flex-shrink-0">💰</span>
              <div class="text-left">
                <p class="text-sm font-semibold">Simulador de Ahorros</p>
                <p class="text-xs mt-0.5 leading-relaxed text-gray-500">Proyecta tu patrimonio, hipoteca e inversiones al detalle.</p>
              </div>
            </button>
            <div class="border-t border-gray-100"></div>
            <button class="cursor-pointer tab-btn flex items-center gap-3 w-full px-5 py-4 text-left" data-tab="retirement">
              <span class="text-lg flex-shrink-0">🏖️</span>
              <div class="text-left">
                <p class="text-sm font-semibold">Calculadora de Jubilación</p>
                <p class="text-xs mt-0.5 leading-relaxed text-gray-500">Planifica cuándo jubilarte gestionando tus ahorros.</p>
              </div>
            </button>
            <div class="border-t border-gray-100"></div>
            <button class="cursor-pointer tab-btn flex items-center gap-3 w-full px-5 py-4 text-left" data-tab="affordability">
              <span class="text-lg flex-shrink-0">🏡</span>
              <div class="text-left">
                <p class="text-sm font-semibold">Calculadora de Hogar</p>
                <p class="text-xs mt-0.5 leading-relaxed text-gray-500">Descubre qué casa te puedes permitir.</p>
              </div>
            </button>
          </div>
          <!-- Desktop tabs -->
          <div class="hidden sm:flex bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden divide-x divide-gray-200">
            <button class="cursor-pointer tab-btn flex flex-1 items-center gap-3 px-5 py-4 text-left transition-all" data-tab="savings">
              <span class="text-lg flex-shrink-0">💰</span>
              <div>
                <p class="text-sm font-semibold">Simulador de Ahorros</p>
                <p class="text-xs mt-0.5 leading-relaxed">Proyecta tu patrimonio, hipoteca e inversiones al detalle.</p>
              </div>
            </button>
            <button class="cursor-pointer tab-btn flex flex-1 items-center gap-3 px-5 py-4 text-left transition-all" data-tab="retirement">
              <span class="text-lg mt-0.5 flex-shrink-0">🏖️</span>
              <div>
                <p class="text-sm font-semibold">Calculadora de Jubilación</p>
                <p class="text-xs mt-0.5 leading-relaxed">Planifica cuándo jubilarte gestionando tus ahorros.</p>
              </div>
            </button>
            <button class="cursor-pointer tab-btn flex flex-1 items-center gap-3 px-5 py-4 text-left transition-all" data-tab="affordability">
              <span class="text-lg mt-0.5 flex-shrink-0">🏡</span>
              <div>
                <p class="text-sm font-semibold">Calculadora de Hogar</p>
                <p class="text-xs mt-0.5 leading-relaxed">Descubre qué casa te puedes permitir.</p>
              </div>
            </button>
          </div>
        </div>
      </div>
    </nav>
    <div id="tab-savings" class="tab-content">
      <SavingsSimulator client:load />
    </div>
    <div id="tab-retirement" class="tab-content hidden">
      <RetirementSimulator client:load />
    </div>
    <div id="tab-affordability" class="tab-content hidden">
      <AffordabilitySimulator client:load />
    </div>
    <script>
      const contents = {
        savings: document.getElementById('tab-savings'),
        retirement: document.getElementById('tab-retirement'),
        affordability: document.getElementById('tab-affordability'),
      };
      const tabBtns = document.querySelectorAll('.tab-btn');
      const mobileTrigger = document.getElementById('nav-mobile-trigger');
      const mobileMenu = document.getElementById('nav-mobile-menu')!;
      const mobileLabel = document.getElementById('nav-mobile-label')!;
      const mobileArrow = document.getElementById('nav-mobile-arrow')!;
      let mobileOpen = false;

      function closeMobile() {
        mobileOpen = false;
        mobileMenu.classList.add('hidden');
        mobileArrow.classList.remove('rotate-180');
      }

      function switchTab(tab: string) {
        localStorage.setItem('nestegg-tab', tab);
        tabBtns.forEach(btn => {
          const isActive = (btn as HTMLElement).dataset.tab === tab;
          btn.classList.toggle('bg-gray-100', isActive);
          btn.classList.toggle('hover:bg-gray-200', isActive);
          btn.classList.toggle('hover:bg-gray-50', !isActive);
          btn.classList.toggle('text-gray-900', !isActive && !btn.closest('#nav-mobile-menu'));
          const desc = btn.querySelector('p:last-child');
          if (btn.closest('#nav-mobile-menu')) {
            btn.classList.toggle('bg-gray-50', isActive);
            btn.classList.toggle('text-gray-900', true);
          } else {
            if (isActive) {
              desc?.classList.add('text-gray-500');
              desc?.classList.remove('text-gray-500');
            } else {
              desc?.classList.remove('text-gray-500');
              desc?.classList.add('text-gray-500');
            }
          }
        });
        const activeDesktopBtn = document.querySelector(`.tab-btn[data-tab="${tab}"]:not(#nav-mobile-menu .tab-btn)`);
        mobileLabel.textContent = activeDesktopBtn?.querySelector('p:first-child')?.textContent ?? '';
        const iconSrc = activeDesktopBtn?.querySelector('.flex-shrink-0');
        if (iconSrc) document.getElementById('nav-mobile-icon')!.innerHTML = iconSrc.innerHTML;
        Object.entries(contents).forEach(([key, el]) => {
          el?.classList.toggle('hidden', key !== tab);
        });
        closeMobile();
      }

      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => switchTab((btn as HTMLElement).dataset.tab ?? ''));
      });

      if (mobileTrigger) {
        mobileTrigger.addEventListener('click', (e) => {
          e.stopPropagation();
          mobileOpen = !mobileOpen;
          mobileMenu.classList.toggle('hidden', !mobileOpen);
          mobileArrow.classList.toggle('rotate-180', mobileOpen);
        });
        document.addEventListener('click', (e) => {
          if (!document.getElementById('nav-container')?.contains(e.target as Node)) {
            closeMobile();
          }
        });
      }

      const savedTab = localStorage.getItem('nestegg-tab') || 'savings';
      switchTab(savedTab);
    </script>
  </body>
</html>
